{
  "title": "Vitae — Usage Guide",
  "sections": [
    {
      "type": "section",
      "title": "Design Philosophy",
      "id": "design-philosophy",
      "content": [
        {
          "type": "list",
          "items": [
            {
              "title": "Frontend-first execution",
              "text": "Sessions run entirely on the client until final submission."
            },
            {
              "title": "Immutable attempt data",
              "text": "Past attempts are preserved exactly as they were taken."
            },
            {
              "title": "Separation of concerns",
              "text": "Questions = source data, Attempts = historical snapshots"
            },
            {
              "title": "Performance-focused workflow",
              "text": "Everything exists to identify weak areas and improve retention."
            }
          ]
        }
      ]
    },
    {
      "type": "section",
      "title": "Session Lifecycle",
      "id": "session-lifecycle",
      "content": [
        {
          "type": "ordered-list",
          "items": [
            "Create session → define scope",
            "Start session → confirm settings",
            "Answer questions → tracked in real time",
            "Review results → performance breakdown",
            "Submit → stored for analytics"
          ]
        }
      ]
    },
    {
      "type": "section",
      "title": "App",
      "id": "app",
      "children": [
