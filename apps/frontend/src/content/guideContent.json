              "type": "list",
              "items": [
                "Question count",
                "Time limit (optional)",
                "Subject",
                "Topics (optional)",
                "Subtopics (optional)",
                "Max attempts"
              ]
            },
            {
              "type": "text",
              "value": "Creates a session draft and prepares it for execution."
            }
          ]
        },
        {
          "type": "subsection",
